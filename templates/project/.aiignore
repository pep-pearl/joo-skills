# AI indexing ignore file
# These paths are excluded from joo-indexing-scan by default. Use --no-respect-ai-ignore only in trusted local scans.

# generated / build output
dist/
build/
.next/
coverage/
**/__generated__/
**/*.generated.*
**/*.gen.*

# large fixtures / snapshots
**/__snapshots__/
**/fixtures/large/

# secrets / private metadata
.env*
secrets/
credentials/
private/
