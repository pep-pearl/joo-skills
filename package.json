{
  "name": "joo-skills",
  "private": true,
  "version": "0.1.0",
  "description": "Personal AI workflow, repo indexing, and agent skill archive.",
  "type": "module",
  "scripts": {
    "scan": "node scripts/joo-indexing-scan.mjs --target . --out .ai/indexing --respect-gitignore --respect-ai-ignore --deny-sensitive-paths --max-map-tokens 1600",
    "install:target": "node scripts/joo-indexing-install.mjs",
    "validate:index": "node scripts/joo-indexing-validate.mjs --target . --index AI_INDEX.md --maps .ai/indexing/maps --warn-only",
    "validate:index:strict": "node scripts/joo-indexing-validate.mjs --target . --index AI_INDEX.md --maps .ai/indexing/maps",
    "refresh:changed": "node scripts/joo-indexing-scan.mjs --target . --out .ai/indexing --respect-gitignore --respect-ai-ignore --deny-sensitive-paths --changed-since main --max-map-tokens 1600"
  },
  "keywords": [
    "ai-skills",
    "agents",
    "repo-indexing",
    "AGENTS.md",
    "AI_INDEX"
  ],
  "license": "MIT"
}
