{
  "name": "joo-skills",
  "private": true,
  "version": "0.1.0",
  "description": "Personal AI workflow, repo indexing, and agent skill archive.",
  "type": "module",
  "scripts": {
    "scan": "node scripts/joo-indexing-scan.mjs --target . --out .ai/indexing --max-map-tokens 1600",
    "install:target": "node scripts/joo-indexing-install.mjs",
    "validate:index": "node scripts/joo-indexing-validate.mjs --target . --index AI_INDEX.md --maps .ai/indexing/maps --warn-only",
    "validate:index:strict": "node scripts/joo-indexing-validate.mjs --target . --index AI_INDEX.md --maps .ai/indexing/maps",
    "refresh:changed": "node scripts/joo-indexing-scan.mjs --target . --out .ai/indexing --changed-since main --max-map-tokens 1600",
    "lookup": "node scripts/joo-indexing-lookup.mjs --target .",
    "diff:impact": "node scripts/joo-diff-impact.mjs --target . --base main",
    "diff:impact:staged": "node scripts/joo-diff-impact.mjs --target . --staged",
    "diff:impact:json": "node scripts/joo-diff-impact.mjs --target . --base main --json",
    "diff:review": "node scripts/joo-diff-impact.mjs --target . --base main --review --include-imports",
    "diff:fix-plan": "node scripts/joo-diff-impact.mjs --target . --base main --fix-plan --include-imports",
    "diff-check": "node scripts/joo-indexing-diff-check.mjs --target . --base main --warn-only",
    "diff-check:strict": "node scripts/joo-indexing-diff-check.mjs --target . --base main",
    "benchmark:navigation": "node scripts/joo-navigation-benchmark.mjs --target .",
    "benchmark": "npm --prefix benchmark/token-navigation run benchmark --",
    "benchmark:check": "npm --prefix benchmark/token-navigation run check",
    "benchmark:dry-run": "npm --prefix benchmark/token-navigation run benchmark:dry-run --",
    "benchmark:finalize": "npm --prefix benchmark/token-navigation run finalize --",
    "benchmark:doctor": "npm --prefix benchmark/token-navigation run doctor --",
    "setup:agy:git-bash": "bash scripts/setup-agy-git-bash.sh",
    "test:lookup": "node scripts/joo-indexing-lookup-self-check.mjs",
    "test": "npm run benchmark:check && npm run test:lookup"
  },
  "keywords": [
    "ai-skills",
    "agents",
    "repo-indexing",
    "AGENTS.md",
    "AI_INDEX",
    "ai-navigation",
    "next-app-router",
    "benchmark",
    "diff-impact",
    "pr-review"
  ],
  "license": "MIT"
}
